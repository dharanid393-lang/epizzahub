{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DatabaseConnection": "Data Source=DELL\\MSSQLSERVER_NEW;Initial Catalog=PB706;Integrated Security=True;TrustServerCertificate=True;"
  },

  "Jwt": {

    "Secret": "2b32201e-50c7-4f2e-b227-52bd65f83867",
    "Issuer": "ePizzaAPI",
    "Audience": "ePizzaUI",
    "TokenExpiryInMinutes": 20

  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Expressions" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "WithMachineName",
      "WithThreadId",
      "WithExceptionDetails",
      "WithEnvironmentName",
      "FromLogContext"
    ],
    "Properties": {
      "Application": "ePizzaAPI"
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{MachineName}|{RequestId}|{SourceContext}] {Message}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-development-.txt",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{MachineName}|{RequestId}|{SourceContext}] {Message}{NewLine}{Exception}",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true,
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      }
    ]
  }
}


